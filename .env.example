# aniFarm — copy to .env.local (not committed)
# Expo loads EXPO_PUBLIC_* at build time.

# mock = simulated API (default) | live = real HTTP to API_URL
EXPO_PUBLIC_API_MODE=mock

# Base URL when API_MODE=live (e.g. https://api.anifarm.app/v1)
EXPO_PUBLIC_API_URL=https://api.anifarm.app/v1

# Set to true when TFLite model is bundled (see lib/ai/inference.native.ts)
EXPO_PUBLIC_USE_TFLITE=false

# Supabase (optional — app runs offline-first without these)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# RevenueCat (optional — without keys, plan changes persist locally for demo)
EXPO_PUBLIC_REVENUECAT_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_KEY_ANDROID=
